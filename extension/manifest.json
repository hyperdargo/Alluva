{
  "manifest_version": 3,
  "name": "Stream Vault Companion",
  "version": "1.0.0",
  "description": "Stream Vault media helper. Downloads, manages, and plays TorrServer playlists.",
  "permissions": [
    "downloads",
    "nativeMessaging",
    "activeTab",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://moviewatch.ankitgupta.com.np/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://moviewatch.ankitgupta.com.np/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["content.js"]
    }
  ]
}
